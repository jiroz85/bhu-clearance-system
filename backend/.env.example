# Copy to .env and adjust. Never commit .env.

DATABASE_URL="postgresql://bhu:bhu@localhost:5432/bhu_clearance?schema=public"

# Use a long random string in production (e.g. openssl rand -base64 32)
JWT_SECRET="replace-with-a-strong-secret-min-32-chars"
JWT_EXPIRES_IN_SEC=604800

PORT=3000

# Frontend origin allowed for CORS with credentials (httpOnly cookies)
CORS_ORIGIN="http://localhost:5173"

# S3 storage (production)
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional for S3-compatible providers (MinIO, Cloudflare R2, etc.)
S3_ENDPOINT=""

# Optional overrides for prisma/seed.ts
# SEED_ADMIN_EMAIL="admin@bhu.edu.et"
# SEED_ADMIN_PASSWORD="ChangeMe_Admin123!"
